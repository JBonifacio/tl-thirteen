# Copy this file to .env and fill in values as needed.
# This project is a static SPA — no server-side env vars are required for the
# game itself. Variables here are for build-time or deployment tooling only.

# Optional: override the Vite dev server port (default: 5173)
# VITE_PORT=5173

# Optional: set a base URL if the app is served from a subdirectory
# VITE_BASE=/
